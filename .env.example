# Build-time (Astro) — site uses this in src/components/bento/LiveKitAgent.tsx
PUBLIC_TOKEN_ENDPOINT=https://yose-livekit-token.<your-subdomain>.workers.dev

# Site build (existing)
TMDB_API_KEY=

# Local agent dev only (src/agent-python/main.py loads ../../.env).
# In production, LiveKit Cloud injects these via the agent secrets manifest.
LIVEKIT_URL=wss://<project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NVIDIA_NIM_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
