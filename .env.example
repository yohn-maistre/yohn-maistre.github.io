# Build-time (Astro consumes via import.meta.env)
PUBLIC_TOKEN_ENDPOINT=https://yose-voice-agent.<your-subdomain>.workers.dev
TMDB_API_KEY=

# Cloudflare Worker secrets — add to GitHub repo Settings → Secrets and the
# deploy-worker workflow will push them into the Worker on every deploy:
#   GEMINI_API_KEY  — Google AI Studio key, scoped to Gemini Live
#   TMDB_API_KEY    — TMDB v3 key (same one used for build-time enrichment)
# No local `wrangler secret put` needed.
