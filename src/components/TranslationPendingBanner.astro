---
/**
 * Shown above EN content when the user is on /id/* but no Indonesian
 * translation exists yet. Provides a clear notice and a link back to the
 * canonical English page.
 */
type Props = {
  enHref: string
}
const { enHref } = Astro.props
---

<aside
  class='translation-pending-banner mb-6 flex flex-col gap-2 rounded-2xl border border-amber-300/40 bg-amber-50/40 p-4 text-sm text-amber-900 sm:flex-row sm:items-center sm:justify-between dark:border-amber-300/20 dark:bg-amber-900/10 dark:text-amber-200'
  role='note'
  aria-label='Translation pending notice'
>
  <div class='flex items-start gap-2'>
    <svg
      xmlns='http://www.w3.org/2000/svg'
      width='18'
      height='18'
      viewBox='0 0 24 24'
      fill='none'
      stroke='currentColor'
      stroke-width='2'
      stroke-linecap='round'
      stroke-linejoin='round'
      class='mt-0.5 shrink-0'
      aria-hidden='true'
    >
      <path d='M5 8l6 6' />
      <path d='M4 14l6-6 2-3' />
      <path d='M2 5h12' />
      <path d='M7 2h1' />
      <path d='M22 22l-5-10-5 10' />
      <path d='M14 18h6' />
    </svg>
    <div>
      <p class='font-medium'>Belum diterjemahkan ke Bahasa Indonesia.</p>
      <p class='text-amber-800/80 dark:text-amber-200/70'>
        Sementara, halaman ini menampilkan versi bahasa Inggris.
      </p>
    </div>
  </div>
  <a
    href={enHref}
    class='shrink-0 self-start rounded-lg border border-amber-400/40 px-3 py-1.5 text-xs font-medium transition-colors hover:bg-amber-100/40 sm:self-auto dark:border-amber-300/30 dark:hover:bg-amber-900/30'
  >
    Lihat versi Inggris &rarr;
  </a>
</aside>
