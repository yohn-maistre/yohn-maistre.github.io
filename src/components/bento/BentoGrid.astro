---
import { SITE, SOCIAL_LINKS } from '@/consts'
import { Icon } from 'astro-icon/components'

import DiscordPresence from '@/components/bento/DiscordPresence.tsx'
import HousePostCanvas from '@/components/bento/HousePostCanvas.tsx'
import VoiceAgent from '@/components/bento/VoiceAgent.tsx'
import SpotifyPresence from '@/components/bento/SpotifyPresence.tsx'
import WakatimeGraph from '@/components/bento/WakatimeGraph.tsx'
import Link from '@/components/Link.astro'
import { getLangFromUrl } from '@/lib/i18n'

const lang = getLangFromUrl(Astro.url)
---

<section
  class='bento-grid'
  aria-label='Personal information and activity grid'
  transition:animate='none'
>
  <div
    class="bento-tile first aspect-square bg-[url('/bento/about-square.webp')] [grid-area:a] sm:aspect-[2.1/1] sm:bg-[url('/bento/about.webp')] xl:aspect-auto"
    role='img'
    aria-label='Introduction'
  >
    <div
      class="overlay size-full rounded-3xl bg-[url('/bento/about-silhouette.webp')] bg-cover bg-center bg-no-repeat opacity-0 transition-opacity duration-200"
    >
    </div>
  </div>

  <div
    class="bento-tile has-overlay aspect-square [grid-area:b] xl:bg-[url('/bento/details-silhouette.webp')]"
    role='img'
    aria-label='Details'
  >
    <div
      class="overlay size-full rounded-3xl bg-[url('/bento/details.webp')] bg-cover bg-center bg-no-repeat transition-opacity duration-200 xl:opacity-0"
    >
    </div>
  </div>

  <div
    class="bento-tile aspect-[1/2.1] bg-[url('/bento/image-1.webp')] [grid-area:c] xl:aspect-auto"
    role='img'
    aria-label='Decorative portrait'
  >
  </div>

  <div
    class='bento-tile relative aspect-square size-full overflow-hidden [grid-area:g] sm:aspect-square'
    aria-label='Discord presence'
  >
    <div style={{ width: '100%', height: '100%' }}>
      <DiscordPresence client:visible />
    </div>
  </div>

  <div
    class='bento-tile three-canvas-container has-overlay relative flex aspect-[6/5] items-center justify-center overflow-hidden p-4 [grid-area:e] hover:bg-none sm:aspect-[2.1/1] xl:aspect-auto'
    aria-label='Voice agent (Aksara)'
  >
    <VoiceAgent client:idle lang={lang} />
  </div>

  <div
    class="bento-tile has-overlay relative aspect-square size-full [grid-area:d] hover:bg-none xl:bg-[url('/bento/spotify-silhouette.webp')]"
  >
    <div style={{ width: '100%', height: '100%' }}>
      <div
        class="overlay absolute inset-0 z-0 size-full rounded-3xl bg-[url('/bento/spotify.webp')] bg-cover bg-center bg-no-repeat transition-opacity duration-200 xl:opacity-0"
      >
      </div>
      <SpotifyPresence client:idle />
    </div>
  </div>

  <div
    class='bento-tile aspect-[1/2.1] [grid-area:h] xl:aspect-auto'
    role='img'
    aria-label='3D model: Iatmul house post'
  >
    <HousePostCanvas client:visible />
  </div>

  <div
    class="bento-tile has-overlay relative flex aspect-square items-center justify-center [grid-area:i] hover:bg-none xl:bg-[url('/bento/github-silhouette.webp')]"
  >
    <div
      class="overlay absolute inset-0 size-full rounded-3xl bg-[url('/bento/github.webp')] bg-cover bg-center bg-no-repeat transition-opacity duration-200 xl:opacity-0"
    >
    </div>
    <Icon
      name='mdi:github'
      class='absolute z-[1] size-1/2 text-primary sm:size-24'
      aria-hidden='true'
    />
    <Link
      href={SOCIAL_LINKS.find((link) => link.label === 'GitHub')?.href || '#'}
      title='Visit my GitHub profile'
      aria-label='Visit my GitHub profile'
    >
      <div
        class='absolute bottom-0 right-0 m-3 flex w-fit items-end rounded-full border bg-secondary/50 p-3 text-primary transition-all duration-300 hover:rotate-12 hover:ring-1 hover:ring-primary'
      >
        <Icon name='lucide:move-up-right' size={16} />
      </div>
    </Link>
  </div>

  <div class='bento-tile aspect-square size-full [grid-area:j]' aria-label='Coding language stats'>
    <div style={{ width: '100%', height: '100%' }}>
      <WakatimeGraph omitLanguages={['Markdown', 'JSON']} client:visible />
    </div>
  </div>

  <div
    class="bento-tile has-overlay relative flex aspect-square items-center justify-center [grid-area:k] hover:bg-none xl:bg-[url('/bento/twitter-silhouette.webp')]"
  >
    <div
      class="overlay absolute inset-0 size-full rounded-3xl bg-[url('/bento/twitter.webp')] bg-cover bg-center bg-no-repeat transition-opacity duration-200 xl:opacity-0"
    >
    </div>
    <Icon
      name='mdi:twitter'
      class='absolute z-[1] size-1/2 text-primary sm:size-24'
      aria-hidden='true'
    />
    <Link
      href={SOCIAL_LINKS.find((link) => link.label === 'Twitter')?.href || '#'}
      title='Visit my Twitter profile'
      aria-label='Visit my Twitter profile'
    >
      <div
        class='absolute bottom-0 right-0 m-3 flex w-fit items-end rounded-full border bg-secondary/50 p-3 text-primary transition-all duration-300 hover:rotate-12 hover:ring-1 hover:ring-primary'
      >
        <Icon name='lucide:move-up-right' size={16} />
      </div>
    </Link>
  </div>
</section>

<style>
  /*
   * Bento grid layout — extracted from inline arbitrary classes so Firefox
   * can parse `grid-template-areas` reliably. The previous UnoCSS arbitrary
   * value `[grid-template-areas:'a_a'_'a_a'_…]` produced CSS that Chromium
   * accepted but Firefox/Zen silently dropped, collapsing the grid.
   */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    padding-inline: 1rem;
    margin-inline: auto;
    max-width: 375px;
    grid-template-areas:
      'a a'
      'a a'
      'b b'
      'b b'
      'e e'
      'h i'
      'h c'
      'k c'
      'd d'
      'd d'
      'g g'
      'g g'
      'j j'
      'j j';
  }

  .bento-tile {
    border-radius: 1.5rem;
    border-width: 1px;
    background-color: hsl(var(--secondary) / 0.25);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  /* Three.js / voice-agent container needs no border or padding */
  .three-canvas-container {
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
  }

  /* Tablet layout */
  @media (min-width: 640px) {
    .bento-grid {
      max-width: 640px;
      grid-template-areas:
        'a a'
        'b d'
        'e e'
        'j g'
        'h i'
        'h c'
        'k c';
    }
  }

  /* Desktop layout */
  @media (min-width: 1280px) {
    .bento-grid {
      max-width: 1280px;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      grid-template-areas:
        'a a b c'
        'd e e c'
        'h e e g'
        'h i j k';
    }

    /* Hover overlays — wrapped in @supports so browsers without :has()
       degrade gracefully instead of failing the whole rule block. */
    @supports selector(:has(*)) {
      .bento-grid:hover:has(> .has-overlay:hover) > .first > .overlay {
        opacity: 1;
      }
      .bento-grid:hover > *:not(.first):hover .overlay {
        opacity: 1;
      }
    }
  }
</style>
