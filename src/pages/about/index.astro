---
import { Button, Collapse, Spoiler, Timeline } from '@yohn-maistre/astro-pure-fork/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'hobbies', text: 'Hobbies' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
  { depth: 2, slug: 'field-notes', text: 'Field Notes' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='About' {headings} comment>
  <p>AI Engineer / Developer / Cultural Technologist</p>
  <p>
    I’m Yose — a software engineer focused on building autonomous agentic architectures and language processing systems. 
    I have a history of working on tactical threat intelligence and multi-agent coordination pipelines for national security. 
    Through <strong>Abstraksi</strong>, I also design decentralized open-data ecosystems, local language models, and community networks 
    tailored for underrepresented languages and indigenous societies in Papua.
  </p>
  <p>
    I view technology as a medium of translation — connecting data with humanity, language with context, and cultural heritage with computation.
  </p>

  {/* hobbies */}
  <h2 id='hobbies'>Hobbies</h2>
  <ul>
    <li>Collecting and curating independent films (the art-house kind, not just mainstream entertainment) and building dedicated music playlists.</li>
    <li>Making music in FL Studio, playing the guitar, and singing.</li>
    <li>Tinkering with hardware, embedded systems, and building custom cyberdecks.</li>
    <li>Reading deeply about technology history and keeping up with AI paradigms since middle school (I remember reading and trying to grasp the original 'Attention is All You Need' paper back in 2017).</li>
    <li>Writing poetry and continuous rambles in my journal, swimming, meditating, and taking aimless road trips on a bike or car to clear my head.</li>
    <li>Spending time with animals, and keeping the memory of my dog Nero alive.</li>
  </ul>

