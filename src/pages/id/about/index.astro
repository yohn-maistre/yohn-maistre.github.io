        description: 'Asisten Pemrograman & Rekayasa Agen',
        href: 'https://github.com/features/copilot',
        icon: import('@/assets/tools/chatgpt.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Design & Media'
    tools={[
      {
        name: 'DaVinci Resolve & CapCut',
        description: 'Penyuntingan Video & Grading Warna',
        href: 'https://www.blackmagicdesign.com/products/davinciresolve',
        icon: import('@/assets/tools/premiere.svg?raw')
      },
      {
