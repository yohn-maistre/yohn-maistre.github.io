      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Productivity & Notes'
    tools={[
      {
        name: 'Zen Browser',
        description: 'Browser Web',
        href: 'https://www.zen-browser.app/',
        icon: import('@/assets/tools/firefox.svg?raw')
      },
      {
        name: 'Obsidian & Notion',
        description: 'Catatan Markdown & Manajemen Pengetahuan',
        href: 'https://obsidian.md/',
