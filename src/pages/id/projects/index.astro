---
import { Image } from 'astro:assets'

import { Button, Collapse, Icon } from '@yohn-maistre/astro-pure-fork/user'
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'
import KeyIcon from '@/assets/icons/key.svg'

const headings = [
  { depth: 2, slug: 'agentic-ai-systems', text: '🤖 Agentic AI Systems' },
  { depth: 3, slug: 'multi-agent-workspaces', text: '👥 Multi-Agent Workspaces' },
  { depth: 3, slug: 'voice-ai', text: '🗣️ Voice AI' },
  { depth: 3, slug: 'defense-intelligence', text: '⚔️ Defense & Intelligence' },
  { depth: 2, slug: 'generative-ai-data-assistants', text: '🔮 Generative AI & Data Assistants' },
  { depth: 2, slug: 'machine-learning-signal-processing', text: '🧪 Machine Learning & Signal Processing' },
  { depth: 2, slug: 'frontend-web-engineering', text: '🎨 Frontend & Web Engineering' },
  { depth: 2, slug: 'systems-algorithms-legacy', text: '👾 Systems, Algorithms & Legacy' },
  { depth: 2, slug: 'gpg-signature', text: 'GPG Signature' }
]
---

<PageLayout title='Proyek' {headings} view>
  <p>Aktivitas GitHub:</p>
  <p>
    <Image
      src='https://ghchart.rshah.org/yohn-maistre'
      alt='github activities'
      inferSize
      loading='lazy'
    />
  </p>
  <p>
    Jika Anda merasa kolaborasi dalam suatu proyek akan berguna atau menarik, jangan ragu untuk menghubungi saya untuk berdiskusi.
  </p>

  <h2 id='agentic-ai-systems'>🤖 Agentic AI Systems</h2>

  <h3 id='multi-agent-workspaces'>👥 Multi-Agent Workspaces</h3>
  <ProjectSection
    projects={[
      {
        name: '📝 Aksara',
        description: `
          <strong class="text-foreground block mb-1">Workspace multi-agen otonom dengan runtime terisolasi untuk eksekusi tugas otomatis.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: Next.js, FastAPI, Python, Daytona Sandbox, tldraw, Supabase, RabbitMQ, Zep/Graphiti</span>
          <p class="text-sm">Platform agen AI untuk mengorkestrasi asisten spesifik dalam mengeksekusi riset, pemrosesan dokumen, dan analisis data. Setiap agen berjalan di dalam container Linux Daytona terisolasi, menggunakan Playwright untuk otomatisasi browser, Tavily untuk pencarian informasi, dan RabbitMQ untuk antrean tugas asinkron.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/aksara' }]
      }
    ]}
  />

  <h3 id='voice-ai'>🗣️ Voice AI</h3>
  <ProjectSection
    projects={[
      {
        name: '🏛️ Philo Fight Club AI',
        description: `
          <strong class="text-foreground block mb-1">Platform debat suara interaktif real-time dengan persona LLM.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: React, Tailwind CSS, Vapi (Voice API), Gemini</span>
          <p class="text-sm">Platform interaktif suara menggunakan Vapi untuk memfasilitasi debat verbal langsung dengan persona filsuf sejarah yang diatur melalui instruksi khusus. Menggunakan aliran audio latensi rendah untuk percakapan tanpa jeda.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/philo-fight-club-ai' }]
      }
    ]}
  />

  <h3 id='defense-intelligence'>⚔️ Defense & Intelligence</h3>
  <ProjectSection
    projects={[
      {
        name: '🦅 Project Cartensz',
        description: `
          <strong class="text-foreground block mb-1">Pipeline triage intelijen ancaman 5 tahap menggunakan klasifikasi lokal dan sintesis LLM.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: Python, SetFit (NusaBERT), Gemini Flash, DuckDB, Qwen-ASR, FastAPI, Streamlit</span>
          <p class="text-sm">Sistem analisis ancaman taktis untuk menyaring feed RSS, Reddit, dan YouTube. Menggunakan model klasifikasi SetFit (NusaBERT) lokal dengan kecepatan 2.500 teks/detik pada CPU untuk menyaring konten aman, lalu meneruskan teks berisiko tinggi ke Gemini Flash untuk penyusunan laporan ringkas.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/project-cartensz' }]
      },
      {
        name: '🛡️ ATLAS Multi-Agent Threat Intel',
        description: `
          <strong class="text-foreground block mb-1">Koordinator intelijen multi-agen untuk pelacakan ancaman dan operasi keamanan taktis.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: LangGraph, LiveKit, Neo4j, DuckDB, NeMo Guardrails, FastAPI</span>
          <p class="text-sm">Sistem orkestrasi intelijen yang mengoordinasikan 7 agen AI spesialis menggunakan LangGraph. Melacak hubungan aktor dan vektor narasi di dalam database graf Neo4j, menggunakan LiveKit untuk komunikasi real-time, dan NeMo Guardrails untuk kepatuhan keamanan data.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/atlas-multi-agent-threat-intel' }]
      }
    ]}
  />

  <h2 id='generative-ai-data-assistants'>🔮 Generative AI & Data Assistants</h2>
  <ProjectSection
    projects={[
      {
        name: '📊 BPS Papua Chat',
        description: `
          <strong class="text-foreground block mb-1">Antarmuka bahasa alami berbasis Streamlit untuk query dan visualisasi data statistik provinsi.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: Streamlit, Python, Pandas, OpenAI/Gemini, Plotly</span>
          <p class="text-sm">Antarmuka bahasa alami untuk kumpulan data sensus resmi dari BPS Papua. Membaca pertanyaan pengguna, memetakan ke file Excel/CSV lokal, melakukan agregasi data via Pandas, dan menampilkan visualisasi grafik interaktif Plotly.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/bps-data-vis-chat' }]
      },
      {
        name: '🏙️ Detak Detik Jayapura',
        description: `
          <strong class="text-foreground block mb-1">Dasbor warga dan portal informasi layanan publik kota Jayapura.</strong> *(legacy, merged with ETNOS)*
          <span class="block text-xs text-primary mb-2">Technologies: React, Vite, TypeScript, shadcn/ui, Tailwind CSS</span>
          <p class="text-sm">Platform pelayanan publik yang mengintegrasikan berita lokal, laporan warga, dan panduan administratif Jayapura. Dirancang untuk digitalisasi akses layanan publik dengan bantuan asisten percakapan lokal.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/detak-detik-jpr' }]
      }
    ]}
  />

  <h2 id='machine-learning-signal-processing'>🧪 Machine Learning & Signal Processing</h2>
  <ProjectSection
    projects={[
      {
        name: '🩺 CareCompass Triage',
        description: `
          <strong class="text-foreground block mb-1">Klasifikasi triase klinik menggunakan model Multi-Task Hierarchical Attention Network (MT-HAN).</strong>
          <span class="block text-xs text-primary mb-2">Technologies: PyTorch, FastAPI, Streamlit, Docker, Multi-Task Hierarchical Attention (MT-HAN)</span>
          <p class="text-sm">Model triase klinik menggunakan arsitektur deep learning Hierarchical Attention Network berbasis PyTorch. Dilatih langsung dari dialog medis, model ini mencapai akurasi rute 95%, mendeteksi kebutuhan pasien, dan mengukur ketidakpastian Bayesian via Monte Carlo Dropout.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/carecompass-clinical-triage' }]
      },
      {
        name: '🫁 Respiratory Diseases Classifier',
        description: `
          <strong class="text-foreground block mb-1">Klasifikasi sinyal akustik untuk identifikasi penyakit pernapasan.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: Streamlit, Librosa, Python, Scikit-learn</span>
          <p class="text-sm">Aplikasi web untuk mengekstrak fitur akustik (mel-spectrogram, chroma, MFCC) dari rekaman suara pernapasan (.wav) menggunakan Librosa, lalu mengklasifikasikannya dengan model Scikit-learn untuk deteksi kondisi pernapasan.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/respiratory-diseases-classifier' }]
      }
    ]}
  />

  <h2 id='frontend-web-engineering'>🎨 Frontend & Web Engineering</h2>
  <ProjectSection
    projects={[
      {
        name: '🌐 Honai Metro',
        description: `
          <strong class="text-foreground block mb-1">Client Fediverse terdesentralisasi berbasis Svelte untuk jejaring komunitas.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: Svelte, Photon framework, Lemmy API, pyfedi</span>
          <p class="text-sm">Client Svelte ringan dengan kustomisasi gaya untuk mengakses jaringan server Lemmy dan Fediverse di Papua. Difork dari Photon dan terintegrasi dengan pyfedi untuk koneksi langsung ke node terdesentralisasi.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/honai-metro' }]
      },
      {
        name: '🌿 yohn-maistre.github.io',
        description: `
          <strong class="text-foreground block mb-1">Portofolio personal dan kebun pikiran dwibahasa yang dibangun dengan Astro.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: Astro, TypeScript, Tailwind CSS, Markdown/MDX</span>
          <p class="text-sm">Mesin di balik portofolio ini, mengintegrasikan loader konten dwibahasa otomatis (i18n), navigasi sidebar dinamis untuk kategori mendalam, dan optimasi performa rendering pada perangkat seluler.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/yohn-maistre.github.io' }]
      }
    ]}
  />

  <Collapse title='👾 Systems, Algorithms & Legacy'>
    <ProjectSection
      projects={[
        {
          name: '⚙️ CyjonOS',
          description: `
            <strong class="text-foreground block mb-1">Sistem operasi multi-tasking yang ditulis dengan Assembly 64-bit.</strong>
            <span class="block text-xs text-primary mb-2">Technologies: Assembly x86_64, Custom Bootloaders, Low-Level Kernel</span>
            <p class="text-sm">Sistem operasi edukatif untuk arsitektur x86_64 yang dibangun dari nol menggunakan bahasa assembly murni. Mengimplementasikan bootloader kustom, manajemen memori paging virtual, scheduler tugas, dan driver perangkat keras dasar.</p>
          `,
          links: [{ type: 'github', href: 'https://github.com/yohn-maistre/CyjonOS' }]
        },
        {
          name: 'forumanak-pb 👦👧',
          description: `
            <strong class="text-foreground block mb-1">Portal web edukatif untuk Forum Anak Papua Barat.</strong>
            <span class="block text-xs text-primary mb-2">Technologies: HTML, CSS, JavaScript, Bootstrap</span>
            <p class="text-sm">Landing page responsif dan pusat informasi untuk memperkuat kehadiran digital dan menyuarakan aspirasi anak-anak di Papua Barat.</p>
          `,
          links: [{ type: 'github', href: 'https://github.com/yohn-maistre/forumanak-pb' }]
        },
        {
          name: 'google-foobar-challenge 🍬',
          description: `
            <strong class="text-foreground block mb-1">Solusi algoritma untuk tantangan rekrutmen rahasia Google Foobar.</strong>
            <span class="block text-xs text-primary mb-2">Technologies: Python, Graph Algorithms, Dynamic Programming, Math</span>
            <p class="text-sm">Repositori berisi solusi algoritma dalam bahasa Python untuk memecahkan tantangan jaringan aliran, rantai Markov, dan pemrograman dinamis dari Google Foobar.</p>
          `,
          links: [{ type: 'github', href: 'https://github.com/yohn-maistre/google-foobar-challenge' }]
        }
      ]}
    />
  </Collapse>

  <!-- gpg signature -->
  <h2 id='gpg-signature'>GPG Signature</h2>
  <p>
    Anda dapat memverifikasi keaslian file yang saya tandatangani dengan memeriksa signature GPG.
    Kunci GPG saya adalah <code>114514</code>, dan Anda dapat menemukannya di server kunci opengpg
    atau mengunduhnya dari sana.
  </p>
  <Button href='https://keys.openpgp.org/search?q=114514' title='Lihat kunci saya' target='_blank'>
    <KeyIcon class='size-5' slot='before' />
  </Button>
</PageLayout>
