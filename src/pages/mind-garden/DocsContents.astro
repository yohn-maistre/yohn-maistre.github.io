---
import { type CollectionEntry } from 'astro:content'
import { getLocalePreferredCollection } from '@yohn-maistre/astro-pure-fork/server'
import { cn } from '@yohn-maistre/astro-pure-fork/utils'

export const prerender = true
export const partial = true

const url = Astro.request.url
const lang = new URL(url).pathname.split('/')[1]
const locale: 'en' | 'id' = lang === 'id' ? 'id' : 'en'

// Union of EN+ID by slug (helper handles orphan inclusion). On EN side,
// current-locale = EN, so ID-only docs surface here too as canonical entries.
const docsCollection = (await getLocalePreferredCollection(
  locale,
  'mind-garden'
)) as CollectionEntry<'mind-garden'>[]

// Group docs by category (the segment immediately after the locale prefix).
const docsByCate = docsCollection.reduce((acc: { [key: string]: typeof docsCollection }, doc) => {
  const parts = doc.id.replace(/\\/g, '/').split('/')
  const category = parts.length > 1 ? parts[1] : parts[0]
  if (!acc[category]) acc[category] = [] as typeof docsCollection
  acc[category].push(doc)
  return acc
}, {})

const docCategories = {
  'setup': 'Setup',
  'integrations': 'Integrations',
  'advanced': 'Advanced',
  'gen-ai': 'Gen AI',
  'training-and-fine-tuning': 'Training & Fine-Tuning',
  'machine-learning': 'Machine Learning',
  'data-science': 'Data Science',
  'programming-languages': 'Programming Languages',
  'security': 'Security',
  'privacy': 'Privacy & Freedom',
  'psychology': 'Psychology',
  'physics': 'Physics & EE',
  'health': 'Health & Mindfulness',
  'general': 'General'
}

type Props = {
  title?: boolean
  class?: string
}

const { title = true, class: className, ...props } = Astro.props
---

<docs-toc class={cn('not-prose', className)} {...props}>
  {title && <h2 class='text-foreground font-semibold'>MIND GARDEN</h2>}
  <ul class='mt-4 flex flex-col gap-y-5'>
    {
      Object.entries(docCategories).map(([id, title]: [string, string]) => (
        <li>
          <h3 class='text-muted-foreground text-xs tracking-widest uppercase'>{title}</h3>
          <ul class='mt-2 flex flex-col'>
            {(docsByCate[id] || [])
              .sort((a, b) => a.data.order - b.data.order)
              .map((doc) => (
                <li class='docs-item flex relative ms-2 px-3 py-1 text-foreground/75 transition-all rounded-2xl'>
                  <a
                    class='flex-1 hover:text-foreground'
                    href={(() => {
                      // Always link to the *current* locale — the route handler
                      // will fall back to EN content with a banner if no ID
                      // translation exists yet.
                      const cleanId = doc.id.replace(/\\/g, '/').replace(/^(en|id)\//, '')
                      return locale === 'id'
                        ? `/id/mind-garden/${cleanId}`
                        : `/mind-garden/${cleanId}`
                    })()}
                  >
                    {doc.data.title}
                  </a>
                </li>
              ))}
          </ul>
        </li>
      ))
    }
  </ul>
</docs-toc>

<style>
  docs-toc .docs-item::before {
    content: '';
    display: block;
    position: absolute;
    top: 5%;
    bottom: 5%;
    left: -0.5rem;
    width: 2px;
    background-color: hsl(var(--input) / var(--un-bg-opacity));
  }

  docs-toc :global(.docs-item.docs-hl) {
    background-color: hsl(var(--muted) / var(--un-bg-opacity));
    font-weight: 500;
    & a {
      color: hsl(var(--primary) / var(--un-text-opacity));
    }

    &::before {
      background-color: hsl(var(--primary) / var(--un-bg-opacity));
    }
  }
</style>

<script>
  class DocsTOC extends HTMLElement {
    link: string = ''

    constructor() {
      super()

      this.link = window.location.pathname
    }

    connectedCallback() {
      const links = this.querySelectorAll('a')
      links.forEach((link) => {
        if (link.getAttribute('href') === this.link) {
          link.parentElement?.classList.add('docs-hl')
        }
      })
    }
  }

  customElements.define('docs-toc', DocsTOC)
</script>
