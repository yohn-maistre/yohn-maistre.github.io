---
import { Button, Icon } from '@yohn-maistre/astro-pure-fork/user'
import { cn } from '@yohn-maistre/astro-pure-fork/utils'
import PageLayout from '@/layouts/BaseLayout.astro'
import { integ } from '../../site.config'

import DocsContents from './DocsContents.astro'

const meta = {
  title: 'Mind Garden',
  description: 'Docs content documentation'
}
---

<PageLayout {meta}>
  <Button title='Back' href='/' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium'>Mind garden</h1>
    </div>

    <div id='content' class={cn('animate mt-8 max-w-none md:min-w-[45ch]', integ.typography.class)}>
      <h2 class='text-xl font-medium'>Most of everything I need to remember, publicly available</h2>
      <p class='text-muted-foreground mt-4 text-sm leading-6'>
        Welcome to my mind garden. This is a personal wiki of things I care to learn, think about, and remember—spanning machine learning, systems design, physics, and mindfulness. Laying ideas here so they can cross-pollinate, because I am tired of forgetting.
      </p>
      <p class='text-muted-foreground mt-2 text-sm italic'>
        (flag: these are old notes from 2020 I had just migrated)
      </p>
      <div class='mt-6 border-b border-muted'></div>
      <DocsContents title={false} />

      <h2 class='text-xl font-medium'>Feedback</h2>
      <p>
        If you have any problems, you can check <a
          href='https://github.com/cworld1/astro-theme-pure/issues'
          target='_blank'>Github Issues</a
        > for community support.
      </p>
      <h2 class='text-xl font-medium'>News Describe (Alpha)</h2>
      <p>
        <a href='/mind-garden/rss.xml' target='_blank'><Icon name='rss' /> </a>
      </p>
    </div>
  </main>
</PageLayout>
