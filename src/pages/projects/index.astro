---
import { Image } from 'astro:assets'

import { Button, Collapse, Icon } from '@yohn-maistre/astro-pure-fork/user'
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'
import KeyIcon from '@/assets/icons/key.svg'

const headings = [
  { depth: 2, slug: 'agentic-ai-systems', text: '🤖 Agentic AI Systems' },
  { depth: 3, slug: 'multi-agent-workspaces', text: '👥 Multi-Agent Workspaces' },
  { depth: 3, slug: 'voice-ai', text: '🗣️ Voice AI' },
  { depth: 3, slug: 'defense-intelligence', text: '⚔️ Defense & Intelligence' },
  { depth: 2, slug: 'generative-ai-data-assistants', text: '🔮 Generative AI & Data Assistants' },
  { depth: 2, slug: 'machine-learning-signal-processing', text: '🧪 Machine Learning & Signal Processing' },
  { depth: 2, slug: 'frontend-web-engineering', text: '🎨 Frontend & Web Engineering' },
  { depth: 2, slug: 'systems-algorithms-legacy', text: '👾 Systems, Algorithms & Legacy' },
  { depth: 2, slug: 'gpg-signature', text: 'GPG Signature' }
]
---

<PageLayout title='Projects' {headings} view>
  <p>Github Activities:</p>
  <p>
    <Image
      src='https://ghchart.rshah.org/yohn-maistre'
      alt='github activities'
      inferSize
      loading='lazy'
    />
  </p>
  <p>
    If you think it would be useful or interesting to collaborate on a project, feel free to contact me to discuss.
  </p>

  <h2 id='agentic-ai-systems'>🤖 Agentic AI Systems</h2>

  <h3 id='multi-agent-workspaces'>👥 Multi-Agent Workspaces</h3>
  <ProjectSection
    projects={[
      {
        name: '📝 Aksara',
        description: `
          <strong class="text-foreground block mb-1">Autonomous multi-agent workspace with sandboxed runtime environments for automated task execution.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: Next.js, FastAPI, Python, Daytona Sandbox, tldraw, Supabase, RabbitMQ, Zep/Graphiti</span>
          <p class="text-sm">An AI agent platform that orchestrates specialized digital experts to execute research, document processing, and data analysis. Each agent runs inside an isolated Daytona Linux container, utilizing Playwright for browser automation, Tavily for search retrieval, and RabbitMQ for asynchronous task queueing.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/aksara' }]
      }
    ]}
  />

  <h3 id='voice-ai'>🗣️ Voice AI</h3>
  <ProjectSection
    projects={[
      {
        name: '🏛️ Philo Fight Club AI',
        description: `
          <strong class="text-foreground block mb-1">Real-time voice debate platform with prompt-driven LLM personas.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: React, Tailwind CSS, Vapi (Voice API), Gemini</span>
          <p class="text-sm">A voice-interactive platform built using Vapi to enable real-time continuous verbal debates with custom-prompted historical philosopher personalities. Leverages low-latency audio streams for uninterrupted conversation.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/philo-fight-club-ai' }]
      }
    ]}
  />

  <h3 id='defense-intelligence'>⚔️ Defense & Intelligence</h3>
  <ProjectSection
    projects={[
      {
        name: '🦅 Project Cartensz',
        description: `
          <strong class="text-foreground block mb-1">Five-stage threat intelligence pipeline using local classification and LLM synthesis.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: Python, SetFit (NusaBERT), Gemini Flash, DuckDB, Qwen-ASR, FastAPI, Streamlit</span>
          <p class="text-sm">A tactical threat analysis pipeline that ingests RSS, Reddit, and YouTube feeds. It uses a locally deployed SetFit (NusaBERT) classifier to filter safe documents at 2,500 texts/sec, forwarding high-risk items to Gemini Flash to compile structured intelligence briefs.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/project-cartensz' }]
      },
      {
        name: '🛡️ ATLAS Multi-Agent Threat Intel',
        description: `
          <strong class="text-foreground block mb-1">Multi-agent threat detection and tactical intelligence coordinator designed for BNPT and TNI defense operations.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: LangGraph, LiveKit, Neo4j, DuckDB, NeMo Guardrails, FastAPI</span>
          <p class="text-sm">An intelligence orchestration system coordinating 7 specialized AI agents using LangGraph. Tracks threat actors and narrative vectors inside a Neo4j knowledge graph, utilizing LiveKit for communication and NeMo Guardrails for data safety and compliance.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/atlas-multi-agent-threat-intel' }]
      }
    ]}
  />

  <h2 id='generative-ai-data-assistants'>🔮 Generative AI & Data Assistants</h2>
  <ProjectSection
    projects={[
      {
        name: '📊 BPS Papua Chat',
        description: `
          <strong class="text-foreground block mb-1">Streamlit-based natural language interface to query and visualize provincial statistics.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: Streamlit, Python, Pandas, OpenAI/Gemini, Plotly</span>
          <p class="text-sm">A natural language interface for official census datasets from BPS Papua. It parses user questions, queries relevant local Excel/CSV files, performs data aggregation via Pandas, and renders dynamic Plotly visualizations.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/bps-data-vis-chat' }]
      },
      {
        name: '🏙️ Detak Detik Jayapura',
        description: `
          <strong class="text-foreground block mb-1">Civic dashboard and administrative information portal for the city of Jayapura.</strong> *(legacy, merged with ETNOS)*
          <span class="block text-xs text-primary mb-2">Technologies: React, Vite, TypeScript, shadcn/ui, Tailwind CSS</span>
          <p class="text-sm">A civic platform integrating local news, community reports, and administrative service guidelines for Jayapura. Built to digitize public service accessibility with localized conversational helpers.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/detak-detik-jpr' }]
      }
    ]}
  />

  <h2 id='machine-learning-signal-processing'>🧪 Machine Learning & Signal Processing</h2>
  <ProjectSection
    projects={[
      {
        name: '🩺 CareCompass Triage',
        description: `
          <strong class="text-foreground block mb-1">Multi-Task Hierarchical Attention Network (MT-HAN) for clinical specialty triage.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: PyTorch, FastAPI, Streamlit, Docker, Multi-Task Hierarchical Attention (MT-HAN)</span>
          <p class="text-sm">A clinical triage classifier using a custom PyTorch Hierarchical Attention Network. Trained from scratch on OSCE clinical dialogues, it achieves 95% specialty routing accuracy, detects patient needs, and uses Monte Carlo Dropout to quantify Bayesian uncertainty.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/carecompass-clinical-triage' }]
      },
      {
        name: '🫁 Respiratory Diseases Classifier',
        description: `
          <strong class="text-foreground block mb-1">Acoustic signal classifier for pulmonary disease identification.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: Streamlit, Librosa, Python, Scikit-learn</span>
          <p class="text-sm">A web application that extracts acoustic features (mel-spectrograms, chroma, and MFCCs) from respiratory breathing audio recordings (.wav) using Librosa, passing them to a Scikit-learn classifier to detect respiratory conditions.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/respiratory-diseases-classifier' }]
      }
    ]}
  />

  <h2 id='frontend-web-engineering'>🎨 Frontend & Web Engineering</h2>
  <ProjectSection
    projects={[
      {
        name: '🌐 Honai Metro',
        description: `
          <strong class="text-foreground block mb-1">Svelte-based decentralized Fediverse client for community networking.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: Svelte, Photon framework, Lemmy API, pyfedi</span>
          <p class="text-sm">A lightweight, custom-styled Svelte client for Papuan Lemmy and Fediverse instances. Forked from Photon and integrated with pyfedi to connect directly to decentralized node networks.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/honai-metro' }]
      },
      {
        name: '🌿 yohn-maistre.github.io',
        description: `
          <strong class="text-foreground block mb-1">Bilingual developer portfolio and digital mind garden built with Astro.</strong>
          <span class="block text-xs text-primary mb-2">Technologies: Astro, TypeScript, Tailwind CSS, Markdown/MDX</span>
          <p class="text-sm">The engine behind this portfolio and the mind garden, featuring an automated bilingual content loader, clean dynamic sidebar routing for nested categories, and optimized build steps for fast rendering on mobile devices.</p>
        `,
        links: [{ type: 'github', href: 'https://github.com/yohn-maistre/yohn-maistre.github.io' }]
      }
    ]}
  />

  <Collapse title='👾 Systems, Algorithms & Legacy'>
    <ProjectSection
      projects={[
        {
          name: '⚙️ CyjonOS',
          description: `
            <strong class="text-foreground block mb-1">Multi-tasking operating system written in pure 64-bit Assembly.</strong>
            <span class="block text-xs text-primary mb-2">Technologies: Assembly x86_64, Custom Bootloaders, Low-Level Kernel</span>
            <p class="text-sm">An educational operating system built from scratch for x86_64 processors. Implements a custom bootloader, virtual memory paging, task schedulers, and basic hardware drivers.</p>
          `,
          links: [{ type: 'github', href: 'https://github.com/yohn-maistre/CyjonOS' }]
        },
        {
          name: 'forumanak-pb 👦👧',
          description: `
            <strong class="text-foreground block mb-1">Web portal for the West Papua Children Forum.</strong>
            <span class="block text-xs text-primary mb-2">Technologies: HTML, CSS, JavaScript, Bootstrap</span>
            <p class="text-sm">A responsive landing page and resource hub designed to increase digital presence and amplify voices of child advocates across West Papua.</p>
          `,
          links: [{ type: 'github', href: 'https://github.com/yohn-maistre/forumanak-pb' }]
        },
        {
          name: 'google-foobar-challenge 🍬',
          description: `
            <strong class="text-foreground block mb-1">Algorithmic solutions for Google's secret recruitment challenge.</strong>
            <span class="block text-xs text-primary mb-2">Technologies: Python, Graph Algorithms, Dynamic Programming, Math</span>
            <p class="text-sm">A repository of algorithmic solutions in Python tackling flow networks, Markov chains, and dynamic programming problems posed by Google's Foobar challenge.</p>
          `,
          links: [{ type: 'github', href: 'https://github.com/yohn-maistre/google-foobar-challenge' }]
        }
      ]}
    />
  </Collapse>

  <!-- gpg signature -->
  <h2 id='gpg-signature'>GPG Signature</h2>
  <p>
    You can verify the authenticity of the files I signed by checking the GPG signature. My GPG key
    is <code>114514</code>, and you can find it on the opengpg key servers or download from it.
  </p>
  <Button href='https://keys.openpgp.org/search?q=114514' title='Checkout my key' target='_blank'>
    <KeyIcon class='size-5' slot='before' />
  </Button>
</PageLayout>
